const SHEET_NAME = "leaveData";
const MEMBERS_SHEET = "members";

function doGet(e) {
  try {
    const action = (e && e.parameter) ? e.parameter.action : null;

    if (action === "getMembers") {
      return getMembers();
    }

    return getLeaves();
  } catch (err) {
    return ContentService.createTextOutput(JSON.stringify({
      status: "error",
      message: err.toString()
    })).setMimeType(ContentService.MimeType.JSON);
  }
}

function doPost(e) {
  try {
    if (!e || !e.postData) {
      return ContentService.createTextOutput(JSON.stringify({
        status: "error",
        message: "No data received"
      })).setMimeType(ContentService.MimeType.JSON);
    }

    const data = JSON.parse(e.postData.contents);

    if (data.action === "addMember") {
      return addMember(data);
    } else if (data.action === "deleteMember") {
      return deleteMember(data);
    } else if (data.action === "skillAssessment") {
      return submitSkillAssessment(data);
    } else {
      return submitLeave(data);
    }
  } catch (err) {
    return ContentService.createTextOutput(JSON.stringify({
      status: "error",
      message: err.toString()
    })).setMimeType(ContentService.MimeType.JSON);
  }
}

function getLeaves() {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(SHEET_NAME);
  if (!sheet) {
    return ContentService.createTextOutput(JSON.stringify({
      status: "error",
      message: "Leave sheet not found"
    })).setMimeType(ContentService.MimeType.JSON);
  }

  const data = sheet.getDataRange().getValues();
  const headers = data[0];
  const leaves = [];

  // Find column indices based on headers
  let snCol = 0, nameCol = 1, idCol = 2, fromCol = 3, toCol = 4, reasonCol = 5, wfhCol = 6, tsCol = 7, durationCol = 8;

  for (let i = 1; i < data.length; i++) {
    const row = data[i];
    if (row[idCol] && row[idCol].toString().trim()) {
      leaves.push({
        sn: row[snCol] || i,
        name: row[nameCol] || "",
        id: row[idCol].toString().trim(),
        from_leave: formatSheetDate(row[fromCol]),
        end_leave: formatSheetDate(row[toCol]),
        reason: row[reasonCol] || "",
        wfh: (row[wfhCol] || "No").toString().trim(),
        timestamp: row[tsCol] || "",
        duration: parseFloat(row[durationCol]) === 0.5 ? 0.5 : 1
      });
    }
  }

  return ContentService.createTextOutput(JSON.stringify({
    status: "success",
    data: leaves
  })).setMimeType(ContentService.MimeType.JSON);
}

function getMembers() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(MEMBERS_SHEET);

  if (!sheet) {
    return ContentService.createTextOutput(JSON.stringify({
      status: "error",
      message: "Members sheet not found"
    })).setMimeType(ContentService.MimeType.JSON);
  }

  const data = sheet.getDataRange().getValues();
  const members = [];

  for (let i = 1; i < data.length; i++) {
    const row = data[i];
    if (row[0]) {
      members.push({
        id: row[0],
        name: row[1],
        role: row[2],
        pin: String(row[3]),
        bg: row[4],
        color: row[5]
      });
    }
  }

  return ContentService.createTextOutput(JSON.stringify({
    status: "success",
    data: members
  })).setMimeType(ContentService.MimeType.JSON);
}

function addMember(data) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(MEMBERS_SHEET);

  if (!sheet) {
    return ContentService.createTextOutput(JSON.stringify({
      status: "error",
      message: "Members sheet not found"
    })).setMimeType(ContentService.MimeType.JSON);
  }

  sheet.appendRow([
    data.id,
    data.name,
    data.role,
    data.pin,
    data.bg,
    data.color
  ]);

  return ContentService.createTextOutput(JSON.stringify({
    status: "success",
    message: "Member added"
  })).setMimeType(ContentService.MimeType.JSON);
}

function deleteMember(data) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(MEMBERS_SHEET);

  if (!sheet) {
    return ContentService.createTextOutput(JSON.stringify({
      status: "error",
      message: "Members sheet not found"
    })).setMimeType(ContentService.MimeType.JSON);
  }

  const sheetData = sheet.getDataRange().getValues();

  for (let i = 1; i < sheetData.length; i++) {
    if (sheetData[i][0] === data.id) {
      sheet.deleteRow(i + 1);
      return ContentService.createTextOutput(JSON.stringify({
        status: "success",
        message: "Member deleted"
      })).setMimeType(ContentService.MimeType.JSON);
    }
  }

  return ContentService.createTextOutput(JSON.stringify({
    status: "error",
    message: "Member not found"
  })).setMimeType(ContentService.MimeType.JSON);
}

function submitLeave(data) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(SHEET_NAME);

  if (!sheet) {
    return ContentService.createTextOutput(JSON.stringify({
      status: "error",
      message: "Leave sheet not found"
    })).setMimeType(ContentService.MimeType.JSON);
  }

  const sn = sheet.getLastRow(); // S.No = row number
  const timestamp = new Date().toLocaleString();

  sheet.appendRow([
    '',
    data.name,
    '',
    data.from_leave,
    data.end_leave,
    data.reason,
    data.wfh || "No",
    timestamp,
    parseFloat(data.duration) === 0.5 ? 0.5 : 1
  ]);

  return ContentService.createTextOutput(JSON.stringify({
    status: "success",
    message: "Leave submitted"
  })).setMimeType(ContentService.MimeType.JSON);
}

function formatSheetDate(date) {
  if (!date) return null;
  if (typeof date === "string") return date;
  const d = new Date(date);
  const year = d.getFullYear();
  const month = String(d.getMonth() + 1).padStart(2, "0");
  const day = String(d.getDate()).padStart(2, "0");
  return `${year}-${month}-${day}`;
}

function submitSkillAssessment(data) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const ASSESSMENT_SHEET = "Skill Assessment";
  let sheet = ss.getSheetByName(ASSESSMENT_SHEET);

  if (!sheet) {
    sheet = ss.insertSheet(ASSESSMENT_SHEET);
    sheet.appendRow([
      "Name", "Background", "Experience", "Submitted At",
      "ign1_rating","ign1_evidence","ign2_rating","ign2_evidence",
      "ign3_rating","ign3_evidence","ign4_rating","ign4_evidence",
      "ign5_rating","ign5_evidence","ign6_rating","ign6_evidence",
      "ign7_rating","ign7_evidence","ign8_rating","ign8_evidence",
      "py1_rating","py1_evidence","py2_rating","py2_evidence",
      "py3_rating","py3_evidence","py4_rating","py4_evidence",
      "py5_rating","py5_evidence","py6_rating","py6_evidence",
      "git1_rating","git1_evidence","git2_rating","git2_evidence",
      "git3_rating","git3_evidence","git4_rating","git4_evidence",
      "git5_rating","git5_evidence",
      "db1_rating","db1_evidence","db2_rating","db2_evidence",
      "db3_rating","db3_evidence","db4_rating","db4_evidence",
      "db5_rating","db5_evidence",
      "ux1_rating","ux1_evidence","ux2_rating","ux2_evidence",
      "ux3_rating","ux3_evidence","ux4_rating","ux4_evidence",
      "mes1_rating","mes1_evidence","mes2_rating","mes2_evidence",
      "mes3_rating","mes3_evidence","mes4_rating","mes4_evidence",
      "inf1_rating","inf1_evidence","inf2_rating","inf2_evidence",
      "inf3_rating","inf3_evidence","inf4_rating","inf4_evidence",
      "inf5_rating","inf5_evidence","inf6_rating","inf6_evidence",
    ]);
  }

  const ids = [
    "ign1","ign2","ign3","ign4","ign5","ign6","ign7","ign8",
    "py1","py2","py3","py4","py5","py6",
    "git1","git2","git3","git4","git5",
    "db1","db2","db3","db4","db5",
    "ux1","ux2","ux3","ux4",
    "mes1","mes2","mes3","mes4",
    "inf1","inf2","inf3","inf4","inf5","inf6",
  ];

  const row = [data.name, data.background, data.experience, data.submitted_at];
  ids.forEach(id => {
    row.push(data[id + "_rating"] !== undefined ? data[id + "_rating"] : "—");
    row.push(data[id + "_evidence"] || "");
  });

  // Upsert by Name (column A): update the professional's existing row if present,
  // otherwise append a new row.
  const existing = sheet.getDataRange().getValues();
  const targetName = (data.name || "").toString().trim().toLowerCase();
  let updatedRow = 0;

  for (let i = 1; i < existing.length; i++) {
    const rowName = (existing[i][0] || "").toString().trim().toLowerCase();
    if (rowName && rowName === targetName) {
      // Sheet rows are 1-based; getRange row = i + 1
      sheet.getRange(i + 1, 1, 1, row.length).setValues([row]);
      updatedRow = i + 1;
      break;
    }
  }

  if (!updatedRow) {
    sheet.appendRow(row);
  }

  return ContentService.createTextOutput(JSON.stringify({
    status: "success",
    message: updatedRow ? "Assessment updated" : "Assessment submitted"
  })).setMimeType(ContentService.MimeType.JSON);
}

function deleteLeave(e) {
  const { id, from_leave, end_leave, wfh } = e.parameter;
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName("Leaves");
  
  if (!sheet) return ContentService.createTextOutput(JSON.stringify({
    status: "error",
    message: "Sheet not found"
  })).setMimeType(ContentService.MimeType.JSON);

  const data = sheet.getDataRange().getValues();
  const headers = data[0];
  
  // Find column indices
  const idCol = headers.indexOf("Member ID") + 1;
  const fromCol = headers.indexOf("From Date") + 1;
  const endCol = headers.indexOf("End Date") + 1;
  const wfhCol = headers.indexOf("WFH") + 1;

  // Find and delete matching row
  for (let i = data.length - 1; i > 0; i--) {
    if (data[i][idCol - 1] == id && 
        data[i][fromCol - 1] == from_leave && 
        data[i][endCol - 1] == end_leave) {
      sheet.deleteRow(i + 1);
      return ContentService.createTextOutput(JSON.stringify({
        status: "success",
        message: "Leave record deleted"
      })).setMimeType(ContentService.MimeType.JSON);
    }
  }

  return ContentService.createTextOutput(JSON.stringify({
    status: "error",
    message: "Record not found"
  })).setMimeType(ContentService.MimeType.JSON);
}
