function doPost(e) {
  try {
    var sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
    var data = JSON.parse(e.postData.contents);

    sheet.appendRow([
      sheet.getLastRow(),
      data.name,
      data.id,
      data.from_leave,
      data.end_leave,
      data.reason,
      data.wfh || "No",
      new Date()
    ]);

    var output = ContentService.createTextOutput(JSON.stringify({ status: "success" }));
    output.setMimeType(ContentService.MimeType.JSON);
    output.addHeader('Access-Control-Allow-Origin', '*');
    return output;
  } catch(err) {
    var output = ContentService.createTextOutput(JSON.stringify({ status: "error", message: err.toString() }));
    output.setMimeType(ContentService.MimeType.JSON);
    output.addHeader('Access-Control-Allow-Origin', '*');
    return output;
  }
}

function doGet() {
  try {
    var sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
    var rows = sheet.getDataRange().getValues();
    var result = [];

    for (var i = 1; i < rows.length; i++) {
      result.push({
        sno:        rows[i][0],
        name:       rows[i][1],
        id:         rows[i][2],
        from_leave: rows[i][3],
        end_leave:  rows[i][4],
        reason:     rows[i][5],
        wfh:        rows[i][6] || "No",
        timestamp:  rows[i][7]
      });
    }

    var output = ContentService.createTextOutput(JSON.stringify({ status: "success", data: result }));
    output.setMimeType(ContentService.MimeType.JSON);
    output.addHeader('Access-Control-Allow-Origin', '*');
    return output;
  } catch(err) {
    var output = ContentService.createTextOutput(JSON.stringify({ status: "error", message: err.toString() }));
    output.setMimeType(ContentService.MimeType.JSON);
    output.addHeader('Access-Control-Allow-Origin', '*');
    return output;
  }
}

function doOptions(e) {
  var output = ContentService.createTextOutput();
  output.setMimeType(ContentService.MimeType.JSON);
  output.addHeader('Access-Control-Allow-Origin', '*');
  output.addHeader('Access-Control-Allow-Methods', 'GET, POST, OPTIONS');
  output.addHeader('Access-Control-Allow-Headers', 'Content-Type');
  return output;
}